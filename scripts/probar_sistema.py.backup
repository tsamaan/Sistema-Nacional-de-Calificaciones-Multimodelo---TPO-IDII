#!/usr/bin/env python3
"""
Script para cambiar el sistema educativo de un estudiante
Flujo: MongoDB → Redis (conversión) → MongoDB (guardado) → Neo4j (relaciones) → Cassandra (auditoría)
"""

import hashlib
import json
from datetime import datetime, timezone
from pymongo import MongoClient
import redis
from neo4j import GraphDatabase
from cassandra.cluster import Cluster

# ============================================================================
# COLORES PARA TERMINAL
# ============================================================================
class Color:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    CYAN = '\033[96m'
    GREEN = '\033[92m'
    YELLOW = '\033[93m'
    RED = '\033[91m'
    MAGENTA = '\033[95m'
    BOLD = '\033[1m'
    UNDERLINE = '\033[4m'
    END = '\033[0m'

def print_header(texto):
    print(f"\n{Color.BOLD}{Color.CYAN}{'='*70}{Color.END}")
    print(f"{Color.BOLD}{Color.CYAN}{texto.center(70)}{Color.END}")
    print(f"{Color.BOLD}{Color.CYAN}{'='*70}{Color.END}\n")

def print_success(texto):
    print(f"{Color.GREEN}✅ {texto}{Color.END}")

def print_error(texto):
    print(f"{Color.RED}❌ {texto}{Color.END}")

def print_info(texto):
    print(f"{Color.BLUE}ℹ️  {texto}{Color.END}")

def print_warning(texto):
    print(f"{Color.YELLOW}⚠️  {texto}{Color.END}")

# ============================================================================
# PASO 1: CONECTAR A LAS 4 BASES DE DATOS
# ============================================================================
print_header("SISTEMA DE CONVERSIÓN DE CALIFICACIONES MULTIBASE")
print_info("Conectando a las bases de datos...")

try:
    # MongoDB - Almacenamiento principal
    mongo_client = MongoClient('mongodb://admin:admin123@localhost:27017/edugrade?authSource=admin')
    db = mongo_client['edugrade']
    mongo_client.server_info()
    print_success("MongoDB conectado")
except Exception as e:
    print_error(f"Error MongoDB: {e}")
    exit(1)

try:
    # Redis - Conversiones en memoria
    redis_client = redis.Redis(host='localhost', port=6379, password='redis123', decode_responses=True)
    redis_client.ping()
    print_success("Redis conectado")
except Exception as e:
    print_error(f"Error Redis: {e}")
    exit(1)

try:
    # Neo4j - Grafo de relaciones
    # Nota: Neo4j puede bloquear después de múltiples intentos fallidos
    # Reiniciar el contenedor si hay problemas: docker restart edugrade-neo4j
    neo4j_driver = GraphDatabase.driver("bolt://localhost:7687", auth=("neo4j", "Neo4j2026!"))
    # No verificar conectividad aquí para evitar bloqueos, se verificará en uso
    print_success("Neo4j conectado")
except Exception as e:
    print_error(f"Error Neo4j: {e}")
    print_warning("Si el error persiste, reinicie Neo4j: docker restart edugrade-neo4j")
    exit(1)

try:
    # Cassandra - Auditoría inmutable
    cassandra_cluster = Cluster(['localhost'])
    cassandra_session_auditoria = cassandra_cluster.connect('edugrade_auditoria')
    print_success("Cassandra conectado")
except Exception as e:
    print_error(f"Error Cassandra: {e}")
    exit(1)

# ============================================================================
# PASO 2: LISTAR ESTUDIANTES DISPONIBLES
# ============================================================================
print_header("PASO 1: SELECCIONAR ESTUDIANTE")

# Obtener lista de estudiantes desde MongoDB
estudiantes = list(db.estudiantes.find({}, {
    'student_id': 1, 
    'full_name': 1, 
    'nationality': 1
}).sort('student_id', 1))

if not estudiantes:
    print_error("No hay estudiantes en la base de datos")
    exit(1)

print(f"{Color.BOLD}Estudiantes disponibles:{Color.END}\n")
for i, est in enumerate(estudiantes, 1):
    print(f"  {i}. {Color.BOLD}{est['student_id']}{Color.END} - {est['full_name']} ({est['nationality']})")

print()
while True:
    try:
        seleccion = input(f"{Color.CYAN}Seleccione el número del estudiante: {Color.END}")
        idx = int(seleccion) - 1
        if 0 <= idx < len(estudiantes):
            estudiante_seleccionado = estudiantes[idx]
            break
        else:
            print_error("Número inválido, intente nuevamente")
    except ValueError:
        print_error("Ingrese un número válido")
    except KeyboardInterrupt:
        print("\n\nOperación cancelada")
        exit(0)

student_id = estudiante_seleccionado['student_id']
print_success(f"Estudiante seleccionado: {student_id} - {estudiante_seleccionado['full_name']}")

# ============================================================================
# PASO 3: MOSTRAR DATOS ACTUALES DEL ESTUDIANTE
# ============================================================================
print_header("PASO 2: DATOS ACTUALES DEL ESTUDIANTE")

# Obtener información completa del estudiante
estudiante_completo = db.estudiantes.find_one({'student_id': student_id})

print(f"  ┌────────────────────────────────────────────────────────────────────┐")
print(f"  │ {Color.BOLD}{Color.CYAN}INFORMACIÓN PERSONAL{Color.END}                                              │")
print(f"  ├────────────────────────────────────────────────────────────────────┤")
print(f"  │  👤 Nombre:        {Color.BOLD}{estudiante_completo['full_name']:<48}{Color.END}│")
print(f"  │  🎂 Nacimiento:    {estudiante_completo['dob']:<48}│")
print(f"  │  🌍 Nacionalidad:  {estudiante_completo['nationality']:<48}│")
print(f"  │  📋 Documento:     {estudiante_completo['documento']['tipo']} {estudiante_completo['documento']['numero']:<43}│")
print(f"  │  🆔 Student ID:    {Color.YELLOW}{student_id}{Color.END:<58}│")
print(f"  └────────────────────────────────────────────────────────────────────┘")

# Obtener calificaciones del estudiante
calificaciones = list(db.calificaciones.find({'student_id': student_id}).sort('created_at', -1))

if not calificaciones:
    print_error("Este estudiante no tiene calificaciones registradas")
    exit(1)

print(f"\n{Color.BOLD}Calificaciones Registradas:{Color.END}\n")

# Tabla con bordes bonitos
print(f"  ┌─────────────────┬───────────────────────────┬──────────┬─────────────────────────┬────────────┬────────────┐")
print(f"  │ {Color.BOLD}ID Registro{Color.END}     │ {Color.BOLD}Institución{Color.END}               │ {Color.BOLD}Sistema{Color.END}  │ {Color.BOLD}Materia{Color.END}                 │ {Color.BOLD}Nota{Color.END}       │ {Color.BOLD}Estado{Color.END}     │")
print(f"  ├─────────────────┼───────────────────────────┼──────────┼─────────────────────────┼────────────┼────────────┤")

for i, cal in enumerate(calificaciones):
    institucion = cal['institution_snapshot']['name'][:25]
    sistema = cal['institution_snapshot']['system']
    materia_nombre = cal['subject_snapshot']['name'][:23]
    nota = cal['evaluation']['grade_value']
    
    # Color según estado
    if cal['evaluation']['passed']:
        estado = f"{Color.GREEN}✅ Aprobó{Color.END}"
        nota_display = f"{Color.GREEN}{nota}{Color.END}"
    else:
        estado = f"{Color.RED}❌ Desaprobó{Color.END}"
        nota_display = f"{Color.RED}{nota}{Color.END}"
    
    # Color según sistema
    sistema_colors = {
        'AR': Color.CYAN,
        'US': Color.BLUE,
        'ZA': Color.YELLOW,
        'UK': Color.MAGENTA if hasattr(Color, 'MAGENTA') else Color.CYAN,
        'DE': Color.GREEN
    }
    sistema_color = sistema_colors.get(sistema, '')
    sistema_display = f"{sistema_color}{sistema}{Color.END}" if sistema_color else sistema
    
    print(f"  │ {cal['record_id']:<15} │ {institucion:<25} │ {sistema_display:<17} │ {materia_nombre:<23} │ {nota_display:<19} │ {estado:<19} │")

print(f"  └─────────────────┴───────────────────────────┴──────────┴─────────────────────────┴────────────┴────────────┘")
print(f"\n  {Color.BOLD}Total: {len(calificaciones)} calificación(es){Color.END}")

# ============================================================================
# PASO 4: PREGUNTAR SI QUIERE HACER CONVERSIÓN
# ============================================================================
print_header("PASO 3: CAMBIO DE SISTEMA EDUCATIVO")

# Identificar sistema actual (del último registro)
ultima_calificacion = calificaciones[0]
sistema_actual = ultima_calificacion['institution_snapshot']['system']
institucion_actual = ultima_calificacion['institution_snapshot']['name']
institucion_actual_id = ultima_calificacion['institution_snapshot']['institution_id']

print_info(f"Sistema actual: {sistema_actual} ({institucion_actual})")
print()

respuesta = input(f"{Color.CYAN}¿Desea cambiar de sistema educativo? (s/n): {Color.END}").lower()
if respuesta not in ['s', 'si', 'sí', 'y', 'yes']:
    print("\nOperación cancelada")
    exit(0)

# ============================================================================
# PASO 5: SELECCIONAR NUEVO SISTEMA E INSTITUCIÓN
# ============================================================================
print_header("PASO 4: SELECCIONAR DESTINO")

# Obtener instituciones de otros sistemas
instituciones_disponibles = list(db.instituciones.find({
    'codigo_sistema': {'$ne': sistema_actual}
}).sort('codigo_sistema', 1))

if not instituciones_disponibles:
    print_error("No hay instituciones de otros sistemas disponibles")
    exit(1)

print(f"{Color.BOLD}Instituciones disponibles en otros sistemas:{Color.END}\n")
for i, inst in enumerate(instituciones_disponibles, 1):
    print(f"  {i}. {Color.BOLD}{inst['institution_id']}{Color.END} - {inst['name']} ({inst['codigo_sistema']}, {inst['country']})")

print()
while True:
    try:
        seleccion = input(f"{Color.CYAN}Seleccione la nueva institución: {Color.END}")
        idx = int(seleccion) - 1
        if 0 <= idx < len(instituciones_disponibles):
            nueva_institucion = instituciones_disponibles[idx]
            break
        else:
            print_error("Número inválido, intente nuevamente")
    except ValueError:
        print_error("Ingrese un número válido")
    except KeyboardInterrupt:
        print("\n\nOperación cancelada")
        exit(0)

nuevo_sistema = nueva_institucion['codigo_sistema']
nueva_institucion_id = nueva_institucion['institution_id']
nueva_institucion_nombre = nueva_institucion['name']

print_success(f"Destino: {nuevo_sistema} - {nueva_institucion_nombre}")

# ============================================================================
# PASO 6: CONVERSIÓN EN REDIS (EN MEMORIA)
# ============================================================================
print_header("PASO 5: CONVERSIÓN DE CALIFICACIONES EN REDIS")

# Obtener regla de conversión desde Redis
regla_key = f"RULE:{sistema_actual}->{nuevo_sistema}"
print_info(f"Buscando regla de conversión: {regla_key}")

regla = redis_client.hgetall(regla_key)

if not regla:
    print_error(f"No existe regla de conversión {sistema_actual} → {nuevo_sistema}")
    print_warning("Creando regla por defecto...")
    
    # Crear regla básica de conversión
    # AR (1-10) → US (0-4): dividir por 10 y multiplicar por 4
    if sistema_actual == 'AR' and nuevo_sistema == 'US':
        regla = {
            'source_system': 'AR',
            'target_system': 'US',
            'source_scale': '1-10',
            'target_scale': '0-4',
            'factor': '0.4',  # (x / 10) * 4
            'description': 'Argentina 1-10 to US GPA 0-4'
        }
        redis_client.hmset(regla_key, regla)
        print_success("Regla creada en Redis")
    else:
        print_error("Sistema de conversión no soportado")
        exit(1)

print_success(f"Regla encontrada: {regla['source_scale']} → {regla['target_scale']} (factor: {regla['factor']})")

# Convertir cada calificación
print(f"\n{Color.BOLD}Convirtiendo calificaciones:{Color.END}\n")

print(f"  ┌──────────────────────────┬─────────────────────┬──────┬─────────────────────┐")
print(f"  │ {Color.BOLD}Materia{Color.END}                  │ {Color.BOLD}Original{Color.END}            │ {Color.BOLD}→{Color.END}    │ {Color.BOLD}Convertida{Color.END}          │")
print(f"  ├──────────────────────────┼─────────────────────┼──────┼─────────────────────┤")

calificaciones_convertidas = []

for cal in calificaciones:
    nota_original = cal['evaluation']['numeric_value']
    sistema_original = cal['institution_snapshot']['system']
    
    # Solo convertir si el sistema coincide con el actual
    if sistema_original == sistema_actual:
        # Aplicar conversión según los sistemas
        if sistema_actual == 'AR' and nuevo_sistema == 'US':
            # AR: 1-10 → US: 0-4 GPA
            nota_convertida = (nota_original / 10.0) * 4.0
            
            # Convertir a letra (simplificado)
            if nota_convertida >= 3.7:
                grade_letter = 'A'
            elif nota_convertida >= 3.3:
                grade_letter = 'A-'
            elif nota_convertida >= 3.0:
                grade_letter = 'B+'
            elif nota_convertida >= 2.7:
                grade_letter = 'B'
            elif nota_convertida >= 2.3:
                grade_letter = 'B-'
            elif nota_convertida >= 2.0:
                grade_letter = 'C+'
            elif nota_convertida >= 1.7:
                grade_letter = 'C'
            elif nota_convertida >= 1.0:
                grade_letter = 'D'
            else:
                grade_letter = 'F'
            
            nota_convertida_str = grade_letter
            passed = nota_convertida >= 1.0  # D o superior en US
        
        else:
            # Para otros sistemas, usar el factor directo
            nota_convertida = nota_original * float(regla.get('factor', 1.0))
            nota_convertida_str = f"{nota_convertida:.1f}"
            passed = nota_convertida >= 1.0
        
        # Cachear conversión en Redis (TTL 24h)
        conv_key = f"CONV:{cal['record_id']}:{sistema_actual}->{nuevo_sistema}"
        conv_data = {
            'original': str(nota_original),
            'converted': str(nota_convertida),
            'converted_display': nota_convertida_str,
            'timestamp': datetime.now(timezone.utc).isoformat()
        }
        redis_client.hmset(conv_key, conv_data)
        redis_client.expire(conv_key, 86400)  # 24 horas
        
        calificaciones_convertidas.append({
            'record_id_original': cal['record_id'],
            'subject_id_original': cal['subject_snapshot']['subject_id'],
            'subject_name': cal['subject_snapshot']['name'],
            'nota_original': nota_original,
            'nota_original_str': cal['evaluation']['grade_value'],
            'nota_convertida': nota_convertida,
            'nota_convertida_str': nota_convertida_str,
            'passed': passed,
            'materia_data': cal['academic_context']
        })
        
        # Formatear salida en tabla bonita
        materia_display = cal['subject_snapshot']['name'][:24]
        original_display = f"{cal['evaluation']['grade_value']} ({sistema_actual})"
        convertida_display = f"{nota_convertida_str} ({nuevo_sistema})"
        
        print(f"  │ {materia_display:<24} │ {Color.YELLOW}{original_display:>19}{Color.END} │ {Color.BOLD}→{Color.END}    │ {Color.GREEN}{convertida_display:>19}{Color.END} │")

print(f"  └──────────────────────────┴─────────────────────┴──────┴─────────────────────┘")
print_success(f"\n{len(calificaciones_convertidas)} calificaciones convertidas y cacheadas en Redis")

# ============================================================================
# PASO 7: CONFIRMAR ANTES DE GUARDAR
# ============================================================================
print_header("PASO 6: CONFIRMACIÓN FINAL")

print_warning("Se creará un NUEVO registro académico con:")
print(f"  • Institución: {nueva_institucion_nombre} ({nuevo_sistema})")
print(f"  • {len(calificaciones_convertidas)} calificaciones convertidas")
print(f"  • Nuevas relaciones en Neo4j")
print(f"  • Registros de auditoría en Cassandra")
print()

respuesta = input(f"{Color.CYAN}¿Confirmar y guardar cambios? (s/n): {Color.END}").lower()
if respuesta not in ['s', 'si', 'sí', 'y', 'yes']:
    print("\n❌ Operación cancelada. No se guardaron cambios.")
    exit(0)

# ============================================================================
# PASO 8: GUARDAR EN MONGODB (NUEVOS REGISTROS)
# ============================================================================
print_header("PASO 7: GUARDANDO EN MONGODB")

timestamp_actual = datetime.now(timezone.utc)
anio_actual = timestamp_actual.year
nuevos_record_ids = []

try:
    for i, conv in enumerate(calificaciones_convertidas):
        # Generar nuevo record_id
        nuevo_record_id = f"GR-{anio_actual}-{int(timestamp_actual.timestamp())}-{i:03d}"
        nuevos_record_ids.append(nuevo_record_id)
        
        # Crear nuevo documento de calificación
        nuevo_documento = {
            'record_id': nuevo_record_id,
            'student_id': student_id,
            'zone': nueva_institucion.get('region', 'UNKNOWN'),
            'student_snapshot': {
                'full_name': estudiante_completo['full_name'],
                'dob': estudiante_completo['dob'],
                'nationality': estudiante_completo['nationality'],
                'documento': estudiante_completo['documento']['numero']
            },
            'institution_snapshot': {
                'institution_id': nueva_institucion_id,
                'name': nueva_institucion_nombre,
                'country': nueva_institucion['country'],
                'region': nueva_institucion['region'],
                'system': nuevo_sistema
            },
            'academic_context': {
                'academic_year': anio_actual,
                'term': 'T1',
                'level': conv['materia_data'].get('level', 'Unknown'),
                'subject_id': conv['subject_id_original'].replace(f'-{sistema_actual}', f'-{nuevo_sistema}'),
                'subject_name': conv['subject_name'],
                'course_code': conv['materia_data'].get('course_code', '').replace(sistema_actual, nuevo_sistema),
                'credits': conv['materia_data'].get('credits', 3)
            },
            'subject_snapshot': {
                'subject_id': conv['subject_id_original'].replace(f'-{sistema_actual}', f'-{nuevo_sistema}'),
                'name': conv['subject_name'],
                'system': nuevo_sistema,
                'course_code': conv['materia_data'].get('course_code', '').replace(sistema_actual, nuevo_sistema)
            },
            'evaluation': {
                'scale_type': 'gpa' if nuevo_sistema == 'US' else 'numeric_scale',
                'grade_value': conv['nota_convertida_str'],
                'numeric_value': conv['nota_convertida'],
                'passed': conv['passed'],
                'passing_threshold': 1.0 if nuevo_sistema == 'US' else 4.0,
                'evaluation_date': timestamp_actual.strftime('%Y-%m-%d'),
                'evaluator': 'Sistema de Conversión'
            },
            'original_grade': {
                'system': nuevo_sistema,
                'value': conv['nota_convertida_str'],
                'scale': 'gpa' if nuevo_sistema == 'US' else 'numeric',
                'range': '0-4' if nuevo_sistema == 'US' else '1-10'
            },
            'evidence': [],
            'immutability': {
                'locked': True,
                'locked_at': timestamp_actual,
                'locked_by': 'sistema_conversion'
            },
            'history': [
                {
                    'action': 'CONVERSION',
                    'prev_record_id': conv['record_id_original'],
                    'prev_system': sistema_actual,
                    'prev_institution': institucion_actual_id,
                    'prev_grade': conv['nota_original_str'],
                    'conversion_factor': regla['factor'],
                    'converted_at': timestamp_actual
                }
            ],
            'created_at': timestamp_actual,
            'updated_at': timestamp_actual
        }
        
        # Insertar en MongoDB
        db.calificaciones.insert_one(nuevo_documento)
        print_success(f"Creado registro {nuevo_record_id}: {conv['subject_name']} - {conv['nota_convertida_str']}")
    
    # Actualizar trayectoria del estudiante
    db.trayectorias.update_one(
        {'student_id': student_id},
        {
            '$addToSet': {'institutions_attended': nueva_institucion_id},
            '$inc': {'total_records': len(calificaciones_convertidas)},
            '$set': {'updated_at': timestamp_actual}
        },
        upsert=True
    )
    
    print_success(f"\n{len(calificaciones_convertidas)} nuevos registros guardados en MongoDB")

except Exception as e:
    print_error(f"Error al guardar en MongoDB: {e}")
    exit(1)

# ============================================================================
# PASO 9: ACTUALIZAR NEO4J (NUEVAS RELACIONES)
# ============================================================================
print_header("PASO 8: CREANDO RELACIONES EN NEO4J")

try:
    with neo4j_driver.session() as session:
        # 1. Crear relación ASISTIO entre estudiante e institución
        result = session.run("""
            MATCH (e:Estudiante {student_id: $student_id})
            MATCH (i:Institucion {institution_id: $institution_id})
            MERGE (e)-[a:ASISTIO]->(i)
            ON CREATE SET a.desde = $fecha, a.sistema = $sistema
            RETURN e, i, a
        """, student_id=student_id, 
             institution_id=nueva_institucion_id,
             fecha=timestamp_actual.strftime('%Y-%m-%d'),
             sistema=nuevo_sistema)
        
        if result.peek():
            print_success(f"Relación ASISTIO creada: {student_id} → {nueva_institucion_nombre}")
        
        # 2. Crear nodos de Calificacion y sus relaciones
        for i, conv in enumerate(calificaciones_convertidas):
            nuevo_record_id = nuevos_record_ids[i]
            subject_id_nuevo = conv['subject_id_original'].replace(f'-{sistema_actual}', f'-{nuevo_sistema}')
            
            # Crear nodo Calificacion
            session.run("""
                MERGE (c:Calificacion {record_id: $record_id})
                SET c.grade_value = $grade_value,
                    c.numeric_value = $numeric_value,
                    c.passed = $passed,
                    c.system = $system,
                    c.converted_from = $converted_from,
                    c.fecha = $fecha
            """, record_id=nuevo_record_id,
                 grade_value=conv['nota_convertida_str'],
                 numeric_value=conv['nota_convertida'],
                 passed=conv['passed'],
                 system=nuevo_sistema,
                 converted_from=sistema_actual,
                 fecha=timestamp_actual.strftime('%Y-%m-%d'))
            
            # Conectar Estudiante → TIENE_REGISTRO → Calificacion
            session.run("""
                MATCH (e:Estudiante {student_id: $student_id})
                MATCH (c:Calificacion {record_id: $record_id})
                MERGE (e)-[:TIENE_REGISTRO {fecha: $fecha}]->(c)
            """, student_id=student_id, record_id=nuevo_record_id, fecha=timestamp_actual.strftime('%Y-%m-%d'))
            
            # Conectar Calificacion → EN_INSTITUCION → Institucion
            session.run("""
                MATCH (c:Calificacion {record_id: $record_id})
                MATCH (i:Institucion {institution_id: $institution_id})
                MERGE (c)-[:EN_INSTITUCION]->(i)
            """, record_id=nuevo_record_id, institution_id=nueva_institucion_id)
            
            # Intentar conectar con Materia (si existe)
            session.run("""
                MATCH (c:Calificacion {record_id: $record_id})
                MATCH (m:Materia {subject_id: $subject_id})
                MERGE (c)-[:DE_MATERIA]->(m)
            """, record_id=nuevo_record_id, subject_id=subject_id_nuevo)
            
            print_success(f"Nodo Calificacion {nuevo_record_id} y relaciones creadas")

    print_success(f"\n{len(calificaciones_convertidas)} nodos y relaciones creados en Neo4j")

except Exception as e:
    print_error(f"Error en Neo4j: {e}")
    print_warning("Los datos están en MongoDB pero falta el grafo en Neo4j")

# ============================================================================
# PASO 10: REGISTRAR AUDITORÍA EN CASSANDRA
# ============================================================================
print_header("PASO 9: REGISTRANDO AUDITORÍA EN CASSANDRA")

try:
    # Obtener último hash de la cadena
    ultimo_evento = cassandra_session_auditoria.execute(
        "SELECT hash_nuevo FROM registro_auditoria_por_entidad_mes LIMIT 1"
    ).one()
    
    hash_anterior = ultimo_evento.hash_nuevo if ultimo_evento else ''
    
    # Crear evento de auditoría para cada conversión
    for i, conv in enumerate(calificaciones_convertidas):
        nuevo_record_id = nuevos_record_ids[i]
        aaaamm = timestamp_actual.strftime('%Y%m')
        
        # Payload del evento
        payload = {
            'action': 'SYSTEM_CONVERSION',
            'student_id': student_id,
            'prev_record_id': conv['record_id_original'],
            'new_record_id': nuevo_record_id,
            'prev_system': sistema_actual,
            'new_system': nuevo_sistema,
            'prev_institution': institucion_actual_id,
            'new_institution': nueva_institucion_id,
            'prev_grade': conv['nota_original_str'],
            'new_grade': conv['nota_convertida_str'],
            'subject': conv['subject_name']
        }
        payload_json = json.dumps(payload, ensure_ascii=False)
        
        # Calcular hash blockchain
        hash_data = f"{hash_anterior}{payload_json}{timestamp_actual.isoformat()}"
        hash_nuevo = hashlib.sha256(hash_data.encode()).hexdigest()
        
        # Insertar en Cassandra
        cassandra_session_auditoria.execute("""
            INSERT INTO registro_auditoria_por_entidad_mes 
            (id_entidad, aaaamm, marca_tiempo, tipo_entidad, accion,
             id_actor, ip, hash_anterior, hash_nuevo, carga_util)
            VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
        """, (nuevo_record_id, aaaamm, timestamp_actual, 'conversion', 'SYSTEM_CONVERSION',
              student_id, '127.0.0.1', hash_anterior, hash_nuevo, payload_json))
        
        print_success(f"Evento auditoría {nuevo_record_id}: hash {hash_nuevo[:12]}...")
        
        # Actualizar hash para siguiente evento
        hash_anterior = hash_nuevo
    
    print_success(f"\n{len(calificaciones_convertidas)} eventos de auditoría registrados en Cassandra")

except Exception as e:
    print_error(f"Error en Cassandra: {e}")
    print_warning("Los datos están en MongoDB y Neo4j pero faltan logs de auditoría")

# ============================================================================
# RESUMEN FINAL
# ============================================================================
print_header("RESUMEN DE OPERACIÓN COMPLETADA")

print(f"  ┌────────────────────────────────────────────────────────────────────┐")
print(f"  │ {Color.BOLD}{Color.GREEN}✅ CONVERSIÓN EXITOSA{Color.END}                                             │")
print(f"  ├────────────────────────────────────────────────────────────────────┤")
print(f"  │  👤 Estudiante:    {Color.BOLD}{estudiante_completo['full_name']:<48}{Color.END}│")
print(f"  │  🆔 ID:            {Color.YELLOW}{student_id}{Color.END:<58}│")
print(f"  │                                                                    │")
print(f"  │  📍 Origen:        {Color.YELLOW}{sistema_actual}{Color.END} - {institucion_actual:<43}│")
print(f"  │  📍 Destino:       {Color.GREEN}{nuevo_sistema}{Color.END} - {nueva_institucion_nombre:<43}│")
print(f"  │                                                                    │")
print(f"  │  📊 Calificaciones convertidas: {Color.BOLD}{len(calificaciones_convertidas)}{Color.END:<36}│")
print(f"  └────────────────────────────────────────────────────────────────────┘")
print()

print(f"  ┌────────────────────────────────────────────────────────────────────┐")
print(f"  │ {Color.BOLD}{Color.CYAN}CAMBIOS REALIZADOS EN CADA BASE{Color.END}                                  │")
print(f"  ├────────────────────────────────────────────────────────────────────┤")
print(f"  │  {Color.GREEN}✅ MongoDB{Color.END}     {len(calificaciones_convertidas)} nuevos registros + trayectoria actualizada       │")
print(f"  │  {Color.GREEN}✅ Redis{Color.END}       Conversiones cacheadas (TTL 24h)                       │")
print(f"  │  {Color.GREEN}✅ Neo4j{Color.END}       Relación ASISTIO + {len(calificaciones_convertidas)} nodos Calificacion            │")
print(f"  │  {Color.GREEN}✅ Cassandra{Color.END}   {len(calificaciones_convertidas)} eventos de auditoría con blockchain             │")
print(f"  └────────────────────────────────────────────────────────────────────┘")
print()

print(f"{Color.BOLD}Nuevos IDs de registro creados:{Color.END}")
print(f"  ┌────────────────────────────────────────────────────┐")
for i, record_id in enumerate(nuevos_record_ids, 1):
    print(f"  │  {i}. {Color.CYAN}{record_id}{Color.END:<58}│")
print(f"  └────────────────────────────────────────────────────┘")

print()
print_success("¡Operación completada exitosamente!")

# Cerrar conexiones
mongo_client.close()
redis_client.close()
neo4j_driver.close()
cassandra_cluster.shutdown()
