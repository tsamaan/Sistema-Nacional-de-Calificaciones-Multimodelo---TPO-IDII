-- EduGrade Global - Seed Cassandra (RF4 + RF5) - 20 registros base (derivados del dataset RF1)
-- RF4: reportes históricos (AP) -> Partition Key = region + academic_year (+ system)
-- RF5: auditoría timeline (CP) -> Partition Key = entity_id + mes_año ; clustering timestamp

-- Keyspace (single-node docker: RF=1; multi-nodo: RF=3)
CREATE KEYSPACE IF NOT EXISTS edugrade WITH replication = {'class':'SimpleStrategy','replication_factor':1};
USE edugrade;

-- =======================
-- RF4 (AP) Reportes históricos
-- Consistencia sugerida para RF4: R=ONE / W=ONE
CONSISTENCY ONE;

CREATE TABLE IF NOT EXISTS rf4_fact_grades_by_region_year_system (
  region text,
  academic_year int,
  system text,
  institution_id text,
  subject_id text,
  event_ts timestamp,
  record_id text,
  student_id text,
  grade_norm_0_100 double,
  grade_raw text,
  passed boolean,
  PRIMARY KEY ((region, academic_year, system), institution_id, subject_id, event_ts, record_id)
) WITH CLUSTERING ORDER BY (institution_id ASC, subject_id ASC, event_ts DESC, record_id ASC);

CREATE TABLE IF NOT EXISTS rf4_report_by_region_year_system (
  region text,
  academic_year int,
  system text,
  institution_id text,
  subject_id text,
  n_records int,
  avg_norm_0_100 double,
  min_norm_0_100 double,
  max_norm_0_100 double,
  pass_rate double,
  updated_at timestamp,
  PRIMARY KEY ((region, academic_year, system), institution_id, subject_id)
);

-- Vista duplicada (cross-system) para comparaciones por región+año
CREATE TABLE IF NOT EXISTS rf4_report_by_region_year (
  region text,
  academic_year int,
  system text,
  institution_id text,
  subject_id text,
  n_records int,
  avg_norm_0_100 double,
  min_norm_0_100 double,
  max_norm_0_100 double,
  pass_rate double,
  updated_at timestamp,
  PRIMARY KEY ((region, academic_year), system, institution_id, subject_id)
) WITH CLUSTERING ORDER BY (system ASC, institution_id ASC, subject_id ASC);

