-- =======================
-- RF5 (CP) Auditoría append-only / timeline
-- Consistencia sugerida para RF5: R=QUORUM / W=QUORUM
CONSISTENCY QUORUM;

CREATE TABLE IF NOT EXISTS rf5_audit_timeline_by_entity_month (
  entity_id text,
  month_bucket text,  -- YYYY-MM
  ts timestamp,
  event_type text,
  actor text,
  ip text,
  record_id text,
  details_json text,
  integrity_hash_sha256 text,
  PRIMARY KEY ((entity_id, month_bucket), ts)
) WITH CLUSTERING ORDER BY (ts ASC);

